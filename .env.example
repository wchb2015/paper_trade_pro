# ---------------------------------------------------------------------------
# Paper Trade Pro — root example env. Copy into backend/.env and edit.
# Secrets live in .env; non-secret rate-limit / timeout settings live in
# backend/src/config.ts and shared/src/constants.ts (typed + checked in).
# ---------------------------------------------------------------------------

# ---- Provider selection ---------------------------------------------------
# The only currently supported provider is "alpaca". Add new providers in
# backend/src/providers/ and extend the PROVIDERS union in shared/src/constants.
PRICE_PROVIDER=alpaca

# ---- Alpaca credentials (SECRET) ------------------------------------------
# Get keys from https://app.alpaca.markets/paper/dashboard/overview
# Use paper-account keys — the same keys work for market data.
APCA_KEY_ID=your-alpaca-key-id
APCA_SECRET_KEY=your-alpaca-secret-key

# ---- Alpaca data feed -----------------------------------------------------
# "iex"  - free tier (IEX exchange only). Use this.
# "sip"  - paid tier (consolidated feed). Requires a market-data subscription.
ALPACA_FEED=iex

# ---- Optional overrides ---------------------------------------------------
# Only set these if you know why.
# ALPACA_DATA_URL=https://data.alpaca.markets
# ALPACA_STREAM_URL=wss://stream.data.alpaca.markets/v2/iex

# ---- Backend -------------------------------------------------------------
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# ---- Postgres (Neon) ------------------------------------------------------
# Connection string for the Neon Postgres instance. Use the pooled URL.
# Schema `paper_trade_pro` must exist; see backend/db/schema.sql for DDLs.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ---- Pre-auth user id -----------------------------------------------------
# Single hardcoded user id that every portfolio request is scoped to until
# we add real login. Swap the getUserId callback in server.ts once a
# session subject exists.
CURRENT_USER_ID=3f7c9b2e-8a41-4d6c-b5f3-1e9a72c4d8ab

# ---- Starting cash --------------------------------------------------------
# Used when auto-provisioning a new account row and on /api/portfolio/reset
# when no explicit amount is passed.
INITIAL_CASH=100000
