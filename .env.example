# ---------------------------------------------------------------------------
# Paper Trade Pro — root example env. Copy to .env at the repo root and edit.
# A SINGLE .env at the repo root serves both backend and frontend:
#   - Backend reads it via dotenv (path resolved from __dirname).
#   - Frontend reads it via Vite (envDir: '..'), but only VITE_* vars are
#     exposed to the browser bundle.
# Never prefix a secret with VITE_ — it will be inlined into the client bundle.
# Non-secret rate limits / timeouts live in backend/src/config.ts and
# shared/src/constants.ts (typed + checked in).
#
# Ports / URLs are configured in ports.cjs at the repo root, NOT here.
# (BACKEND_PORT, FRONTEND_DEV_PORT, BACKEND_URL, FRONTEND_DEV_URL)
# ---------------------------------------------------------------------------

# ---- Provider selection ---------------------------------------------------
# Supported:
#   alpaca  - live data via Alpaca's WebSocket (requires market hours)
#   replay  - off-hours dev: replays NDJSON files downloaded by fetchTrades.ts
# Add new providers in backend/src/providers/ and extend the PROVIDERS union
# in shared/src/constants.
PRICE_PROVIDER=alpaca

# ---- Alpaca credentials (SECRET) ------------------------------------------
# Get keys from https://app.alpaca.markets/paper/dashboard/overview
# Use paper-account keys — the same keys work for market data.
APCA_KEY_ID=your-alpaca-key-id
APCA_SECRET_KEY=your-alpaca-secret-key

# ---- Alpaca data feed -----------------------------------------------------
# "iex"  - free tier (IEX exchange only). Use this.
# "sip"  - paid tier (consolidated feed). Requires a market-data subscription.
ALPACA_FEED=iex

# ---- Optional overrides ---------------------------------------------------
# Only set these if you know why.
# ALPACA_DATA_URL=https://data.alpaca.markets
# ALPACA_STREAM_URL=wss://stream.data.alpaca.markets/v2/iex

# ---- Postgres (Neon) ------------------------------------------------------
# Connection string for the Neon Postgres instance. Use the pooled URL.
# Schema `paper_trade_pro` must exist; see backend/db/schema.sql for DDLs.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ---- Pre-auth user id -----------------------------------------------------
# Single hardcoded user id that every portfolio request is scoped to until
# we add real login. Swap the getUserId callback in server.ts once a
# session subject exists.
CURRENT_USER_ID=3f7c9b2e-8a41-4d6c-b5f3-1e9a72c4d8ab

# ---- Starting cash --------------------------------------------------------
# Used when auto-provisioning a new account row and on /api/portfolio/reset
# when no explicit amount is passed.
INITIAL_CASH=100000

# ---- Replay data downloader ----------------------------------------------
# Off-hours development: download historical trades via REST and replay them
# through our own Socket.io so the UI looks alive. The downloader reads the
# same Alpaca creds above; no extra env is required. Usage:
#   cd backend && npm run fetch-trades -- TSLA 2026-05-01 09:30 10:30
# Output lands in backend/.replay-cache/<date>/<symbol>.ndjson (gitignored).

# ---- ReplayProvider (only used when PRICE_PROVIDER=replay) ----------------
# Which date to replay (folder name under backend/.replay-cache/).
REPLAY_DATE=2026-05-01
# 1 = real-time, 10 = 10x faster, 0 = as-fast-as-possible (stress test).
REPLAY_SPEED=1
# Restart from the beginning after EOD so the feed never dies.
REPLAY_LOOP=true
# Optional absolute path override for the cache root.
# REPLAY_CACHE_DIR=

# ---- Frontend (Vite) ------------------------------------------------------
# Only VITE_*-prefixed vars are exposed to the client bundle.
# Note: VITE_BACKEND_URL is NOT here — it is injected at build time from
# ports.cjs (repo root) via vite.config.ts `define`. See ports.cjs.

# Refresh cadence for re-fetching snapshots over REST (ms). The socket
# delivers trade ticks continuously; this covers bid/ask/OHLC drift.
VITE_SNAPSHOT_REFRESH_MS=30000

# A symbol with no tick for this long is shown as "stale" (ms).
VITE_STALE_AFTER_MS=60000

