# ---------------------------------------------------------------------------
# Paper Trade Pro — copy to .env at the repo root and fill in.
# A single root .env serves both backend (dotenv) and frontend (Vite, only
# VITE_*-prefixed vars). Never put a secret behind VITE_ — it ships to the
# browser. Ports/URLs live in ports.cjs, not here.
# ---------------------------------------------------------------------------

# ============================ REQUIRED ====================================
APCA_KEY_ID=
APCA_SECRET_KEY=
DATABASE_URL=

# ============================ OPTIONAL ====================================
# All have safe defaults — uncomment only to override.
# PRICE_PROVIDER=alpaca
# ALPACA_FEED=iex
# ALPACA_DATA_URL=
# ALPACA_TRADING_URL=
# ALPACA_STREAM_URL=
# CURRENT_USER_ID=
# INITIAL_CASH=100000
# REPLAY_DATE=2026-05-01
# REPLAY_SPEED=1
# REPLAY_LOOP=true
# REPLAY_CACHE_DIR=
# VITE_SNAPSHOT_REFRESH_MS=30000
# VITE_STALE_AFTER_MS=60000

# ============================ REFERENCE ===================================
# Each variable explained, with a sample value.
#
# --- Required ---
#
# APCA_KEY_ID            Alpaca paper-account key id (also used for market data).
#                        Get from https://app.alpaca.markets/paper/dashboard/overview
#                        e.g. APCA_KEY_ID=PKXXXXXXXXXXXXXXXXXX
#
# APCA_SECRET_KEY        Alpaca paper-account secret key. Pair with APCA_KEY_ID.
#                        e.g. APCA_SECRET_KEY=abcdefghijklmnopqrstuvwxyz0123456789ABCD
#
# DATABASE_URL           Postgres connection string (Neon pooled URL recommended).
#                        Schema `paper_trade_pro` must exist — see backend/db/schema.sql.
#                        e.g. DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
#
# --- Optional ---
#
# PRICE_PROVIDER         Which feed to use. Default: alpaca.
#                          alpaca  — live data over WebSocket (market hours only).
#                          replay  — off-hours dev: replays NDJSON files dumped by
#                                    `npm run fetch-trades` through our Socket.io.
#                        Add new providers under backend/src/providers/ and extend
#                        the PROVIDERS union in shared/src/constants.
#                        e.g. PRICE_PROVIDER=replay
#
# ALPACA_FEED            Alpaca data tier. Default: iex.
#                          iex  — free (IEX exchange only).
#                          sip  — paid (consolidated feed; needs subscription).
#                        e.g. ALPACA_FEED=sip
#
# ALPACA_DATA_URL        Override the Alpaca market-data REST base URL (snapshots,
#                        bars). Only set if you know why.
#                        Default: https://data.alpaca.markets
#                        e.g. ALPACA_DATA_URL=https://data.alpaca.markets
#
# ALPACA_TRADING_URL     Override the Alpaca trading-API base URL (assets catalog
#                        used by /api/assets/lookup). Defaults to the paper host
#                        since this app is paper-only.
#                        Default: https://paper-api.alpaca.markets
#                        e.g. ALPACA_TRADING_URL=https://api.alpaca.markets
#
# ALPACA_STREAM_URL      Override the Alpaca WebSocket URL. Default is derived from
#                        ALPACA_FEED: wss://stream.data.alpaca.markets/v2/<feed>.
#                        e.g. ALPACA_STREAM_URL=wss://stream.data.alpaca.markets/v2/iex
#
# CURRENT_USER_ID        Pre-auth: every portfolio request is scoped to this user_id.
#                        Swap the getUserId callback in server.ts once real login
#                        lands. Default: 3f7c9b2e-8a41-4d6c-b5f3-1e9a72c4d8ab
#                        e.g. CURRENT_USER_ID=3f7c9b2e-8a41-4d6c-b5f3-1e9a72c4d8ab
#
# INITIAL_CASH           Starting cash for auto-provisioned accounts and the
#                        /api/portfolio/reset endpoint when no amount is passed.
#                        Default: 100000
#                        e.g. INITIAL_CASH=250000
#
# REPLAY_DATE            (PRICE_PROVIDER=replay only) Folder under
#                        backend/.replay-cache/ to read. Default: 2026-05-01
#                        e.g. REPLAY_DATE=2026-05-01
#
# REPLAY_SPEED           (replay only) Playback rate. Default: 1
#                          1   = real-time
#                          10  = 10× faster
#                          0   = as-fast-as-possible (stress test)
#                        e.g. REPLAY_SPEED=10
#
# REPLAY_LOOP            (replay only) Restart from EOD so the feed never dies.
#                        Default: true
#                        e.g. REPLAY_LOOP=false
#
# REPLAY_CACHE_DIR       (replay only) Absolute path override for the NDJSON root.
#                        Default: backend/.replay-cache
#                        e.g. REPLAY_CACHE_DIR=/Users/me/replay-cache
#
# VITE_SNAPSHOT_REFRESH_MS  Frontend: REST snapshot refresh cadence (ms). The
#                           socket streams ticks; this covers bid/ask/OHLC drift.
#                           Default: 30000
#                           e.g. VITE_SNAPSHOT_REFRESH_MS=30000
#
# VITE_STALE_AFTER_MS    Frontend: a symbol with no tick for this long is shown
#                        as "stale" (ms). Default: 60000
#                        e.g. VITE_STALE_AFTER_MS=60000
#
# --- Replay downloader (no env needed) ---
# Reuses APCA_* above. Usage:
#   cd backend && npm run fetch-trades -- TSLA 2026-05-01 09:30 10:30
# Output: backend/.replay-cache/<date>/<symbol>.ndjson (gitignored).

# ============================ AUTH (Phase 1) ==============================
# Google OAuth — required for /api/auth/google/* to work. Set BYPASS_AUTH=1
# instead if you don't have a client yet.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:5011/api/auth/google/callback

# Session cookie tunables — safe defaults; override only if you know why.
# SESSION_COOKIE_NAME=ptp_sid
# SESSION_LIFETIME_MS=2592000000

# Dev-only escape hatch. Refused under NODE_ENV=production.
# BYPASS_AUTH=1

# ============================ AUTH REFERENCE ==============================
#
# GOOGLE_CLIENT_ID         OAuth client ID from Google Cloud Console.
#                          Console → APIs & Services → Credentials → Create
#                          OAuth client → Web application.
#                          e.g. GOOGLE_CLIENT_ID=12345-abc.apps.googleusercontent.com
#
# GOOGLE_CLIENT_SECRET     OAuth client secret. Pair with GOOGLE_CLIENT_ID.
#                          NEVER prefix with VITE_ — it would ship to the browser.
#                          e.g. GOOGLE_CLIENT_SECRET=GOCSPX-abcdefghij
#
# GOOGLE_REDIRECT_URI      Where Google sends the auth code. MUST be one of
#                          the "Authorized redirect URIs" registered on the
#                          Google client. Local dev points at the Vite dev
#                          server (:5011), which proxies /api to the backend.
#                          Default: http://localhost:5011/api/auth/google/callback
#                          Prod:    https://papertrade.pro/api/auth/google/callback
#
# SESSION_COOKIE_NAME      Cookie name for the server-side session id.
#                          Default: ptp_sid
#
# SESSION_LIFETIME_MS      Session cookie Max-Age, in milliseconds.
#                          Default: 2592000000 (30 days)
#
# BYPASS_AUTH              Dev-only. When 1, every authenticated request is
#                          fulfilled with the demo user — no Google client
#                          required. Refused when NODE_ENV=production. Logs
#                          a WARN at backend boot when active.
#                          e.g. BYPASS_AUTH=1
