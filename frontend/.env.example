# Frontend build-time config. Copy to frontend/.env.local to override.
# All values are optional — sensible defaults are in frontend/src/config.ts.

# URL of the backend (where price REST + socket live).
VITE_BACKEND_URL=http://localhost:4000

# Refresh cadence for re-fetching snapshots over REST (ms). The socket
# delivers trade ticks continuously; this covers bid/ask/OHLC drift.
VITE_SNAPSHOT_REFRESH_MS=30000

# A symbol with no tick for this long is shown as "stale" (ms).
VITE_STALE_AFTER_MS=60000
